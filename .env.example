# Credenciales Telegram — obtener en https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=bot_session

# IDs numéricos de canales autorizados, separados por coma
# Ejemplo: WHITELIST_CHANNELS=-1001234567890,-1009876543210
WHITELIST_CHANNELS=

# Clave HMAC para firmar señales
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
HMAC_SECRET=

# ---------------------------------------------------------------------------
# Modo de ejecución
# ---------------------------------------------------------------------------

# Modo seguro — cambiar a False solo cuando estés listo para ejecutar en DEMO/REAL
DRY_RUN=True

# REQUERIDO cuando DRY_RUN=False — confirmación explícita para evitar accidentes
# Setear a "true" (en minúsculas) solo cuando estés seguro de operar en cuenta real
CONFIRM_LIVE=

# ---------------------------------------------------------------------------
# Servidor local (no cambiar host)
# ---------------------------------------------------------------------------
API_HOST=127.0.0.1
API_PORT=8080

# ---------------------------------------------------------------------------
# Símbolos permitidos
# ---------------------------------------------------------------------------
WHITELIST_SYMBOLS=XAUUSD,EURUSD,GBPUSD,USDJPY,GBPJPY

# ---------------------------------------------------------------------------
# Logging a archivo (opcional — si vacío, solo escribe a stdout)
# En producción: descomentar y usar rutas absolutas o relativas al proyecto
# ---------------------------------------------------------------------------
LOG_FILE_SERVER=logs/server.log
LOG_FILE_LISTENER=logs/listener.log

# ---------------------------------------------------------------------------
# Alertas por Telegram (opcional)
# Crear un bot en @BotFather, obtener token y chat_id propio
# ---------------------------------------------------------------------------
ALERT_BOT_TOKEN=
ALERT_CHAT_ID=

# ---------------------------------------------------------------------------
# Configuración EA / cuenta (documentación — se setea en MT5, no en el EA)
# ---------------------------------------------------------------------------
# LOT_SIZE inicial: 0.01 (paper trading) → 0.03 (live inicial) → máx 0.05
# MT5_SERVER=VTMarkets-Demo  (demo) | VTMarkets-Live7 (real)
# MT5_ACCOUNT=<número de cuenta>
# SYMBOL=XAUUSD-STD
